<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SimplePlayer" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.SimplePlayer.Launch" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.SimplePlayer.SystemSplash" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/splash_gradient</item>
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.SimplePlayer.Launch</item>
    </style>
</resources>